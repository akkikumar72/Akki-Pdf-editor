{
  "name": "akki-pdf-editor",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "overrides": {
    "@eslint/plugin-kit": ">=0.3.4"
  },
  "scripts": {
    "postinstall": "git config core.hooksPath .githooks || true",
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "test:coverage": "vitest run --config vitest.config.ts --coverage --coverage.include='src/**'",
    "e2e": "playwright test",
    "smoke": "bash scripts/smoke-test.sh",
    "video:studio": "remotion studio video/index.ts --public-dir=video/public",
    "video:typecheck": "tsc --noEmit -p video/tsconfig.json",
    "video:storyboard": "mkdir -p video/out && remotion still video/index.ts AkkiShowcase video/out/storyboard.png --frame=405 --public-dir=video/public",
    "video:poster": "remotion still video/index.ts AkkiShowcasePoster video/public/akki-pdf-showcase-poster.png --public-dir=video/public",
    "video:render": "bash video/render.sh"
  },
  "dependencies": {
    "@pdf-lib/fontkit": "^1.1.1",
    "@radix-ui/react-slot": "^1.2.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fflate": "^0.8.3",
    "lucide-react": "^0.468.0",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "4.8.69",
    "perfect-freehand": "^1.2.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-pdf": "^9.2.1",
    "react-router-dom": "^7.17.0",
    "react-select": "^5.10.2",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@eslint/js": "9.17.0",
    "@playwright/test": "^1.49.1",
    "@remotion/cli": "4.0.489",
    "@remotion/google-fonts": "4.0.489",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "4.1.8",
    "eslint": "9.17.0",
    "eslint-plugin-react-hooks": "5.1.0",
    "eslint-plugin-react-refresh": "0.4.16",
    "fake-indexeddb": "6.0.0",
    "globals": "15.14.0",
    "jsdom": "^29.1.1",
    "prettier": "3.4.2",
    "remotion": "4.0.489",
    "typescript": "^5.7.2",
    "typescript-eslint": "8.18.2",
    "vite": "^8.0.16",
    "vite-plugin-static-copy": "^4.1.1",
    "vitest": "^4.1.8"
  }
}

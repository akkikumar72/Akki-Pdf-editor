#!/bin/sh
# Strip trailing co-author / assistant-session attribution lines from every
# commit message, regardless of who or what appended them. Portable POSIX.
msg="$1"
tmp="$msg.strip.$$"

grep -viE '^[[:space:]]*(Co-authored-by|Claude-Session)[[:space:]]*:' "$msg" > "$tmp"

awk '{a[NR]=$0}
     END{last=NR; while(last>0 && a[last] ~ /^[[:space:]]*$/) last--;
         for(i=1;i<=last;i++) print a[i]}' "$tmp" > "$msg"

rm -f "$tmp"
exit 0
